        overflow: hidden;
    }

    #premium-swipey-bar::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 200%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 77, 166, 0.3), transparent);
        animation: bg-move 3s linear infinite;
        pointer-events: none;
    }

    .bar-inner {
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 30px;
        width: 100%;
        height: 100%;
        position: relative;
        z-index: 2;
    }

    .main-title {
        color: #fff;
        font-family: 'Orbitron', sans-serif;
        font-weight: 900;
        font-size: 19px;
        letter-spacing: 0.5px;
        background: linear-gradient(90deg, #ff66b2, #ff4d4d, #ff99cc, #ff66b2);
        background-size: 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: text-shine 2.5s linear infinite;
        white-space: nowrap;
        text-shadow: 0 0 15px rgba(255, 102, 178, 0.3);
    }

    .cyber-button {
        background: linear-gradient(135deg, #ff1a8c, #ff4d4d);
        color: #fff;
        padding: 12px 32px;
        border-radius: 6px;
        font-weight: 900;
        font-family: 'Orbitron', sans-serif;
        font-size: 15px; 
        letter-spacing: 2.5px;
        text-transform: uppercase;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 2px solid rgba(255, 255, 255, 0.9);
        box-shadow: 0 0 18px rgba(255, 26, 140, 0.6), inset 0 0 8px rgba(255, 255, 255, 0.3);
        white-space: nowrap;
        animation: button-pulse 2s infinite alternate;
    }

    .bar-inner:hover .cyber-button {
        background: linear-gradient(135deg, #ff4da6, #ff7373);
        box-shadow: 0 0 28px #ff1a8c, inset 0 0 12px rgba(255, 255, 255, 0.5);
        transform: scale(1.05);
        border-color: #fff;
    }

    @keyframes button-pulse {
        0% {
            box-shadow: 0 0 12px rgba(255, 26, 140, 0.5), inset 0 0 5px rgba(255, 255, 255, 0.2);
        }
        100% {
            box-shadow: 0 0 22px rgba(255, 26, 140, 0.85), inset 0 0 10px rgba(255, 255, 255, 0.4);
        }
